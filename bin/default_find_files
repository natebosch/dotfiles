#!/bin/bash

if command -v ag >/dev/null; then
  ag -l --nocolor --nogroup --depth 10 --hidden --ignore .git/
else
  command find -L . \
    \( -name .git -o -path '*/\\.*' -o -fstype 'dev' -o -fstype 'proc' \) -prune \
    -o -type f -print \
    -o -type l -print 2>/dev/null | awk 'NR>1 {print substr($0, 3)}'
fi
