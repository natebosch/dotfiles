#!/bin/bash

branch="$1"
if [ -z "$branch" ]; then
  echo "Usage: git drop <branch>"
  exit 1
fi

is_checked_out() {
  local b="$1"
  git worktree list | awk -v b="$b" '{gsub(/[\[\]]/, "", $NF); if ($NF == b) found=1} END {exit !found}'
}

current_branch=$(git branch --show-current)

if is_checked_out "$branch"; then
  if [ "$current_branch" != "$branch" ]; then
    echo "Error: Branch $branch is currently checked out in a worktree."
    echo "Press Enter to continue..."
    read -r _ < /dev/tty
    exit 1
  fi

  fallback=""
  remote=$(git config --get "branch.$branch.remote")
  merge=$(git config --get "branch.$branch.merge")
  local_upstream=""

  if [ "$remote" = "." ] && [[ "$merge" == refs/heads/* ]]; then
    local_upstream="${merge#refs/heads/}"
    if ! is_checked_out "$local_upstream"; then
      fallback="$local_upstream"
    fi
  fi

  main_branch=$(git mainbranch)

  if [ -z "$fallback" ]; then
    if ! is_checked_out "$main_branch"; then
      fallback="$main_branch"
    else
      if [ -n "$local_upstream" ]; then
        bk="${local_upstream}-kedgebk"
        if ! is_checked_out "$bk"; then
          fallback="$bk"
          if ! git show-ref --verify --quiet "refs/heads/$bk"; then
            git branch "$bk" "$local_upstream"
          fi
        else
          echo "Error: Backup branch $bk is currently checked out in a worktree."
          echo "Press Enter to continue..."
          read -r _ < /dev/tty
          exit 1
        fi
      else
        bk="${main_branch}-kedgebk"
        if ! is_checked_out "$bk"; then
          fallback="$bk"
          if ! git show-ref --verify --quiet "refs/heads/$bk"; then
            git branch "$bk" "$main_branch"
          fi
        else
          echo "Error: Backup branch $bk is currently checked out in a worktree."
          echo "Press Enter to continue..."
          read -r _ < /dev/tty
          exit 1
        fi
      fi
    fi
  fi

  if [ -n "$fallback" ]; then
    git checkout "$fallback"
  fi
fi

if ! git branch -d "$branch"; then
  echo
  echo "============================================================"
  echo "Latest commit in $branch:"
  echo "============================================================"
  git --no-pager log -1 -p "$branch"
  echo
  echo "============================================================"
  echo "Commits unique to $branch:"
  echo "============================================================"
  git --no-pager log --graph \
    --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' \
    --abbrev-commit --date=relative --boundary \
    "$branch" --not --exclude="$branch" --branches
  echo
  echo
  confirm "Force delete $branch?" && git branch -D "$branch"
fi
