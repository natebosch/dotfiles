#!/bin/bash

set -e

git rev-parse --is-inside-work-tree >/dev/null

longest_branch=$(($(git branch --format="%(refname:short)" | wc -L) + 8))
longest_upstream=$(($(git branch --format="%(upstream:short)" | wc -L) + 2))

branch="%(align:$longest_branch)\
%(if)%(HEAD)%(then)%(color:green)%(else)%(color:reset)%(end)\
%(refname:short)%(color:reset)\
%(end)"
upstream="%(align:$longest_upstream)\
%(upstream:short) %(upstream:trackshort)\
%(end)"
commit="%(objectname:short)  %(subject)"


preview="git config branch.{1}.description;\
  git show --color=always -m {1} | diffr"

if [ "$1" == "--list-only" ]; then
  git branch --sort=-committerdate --format="$branch $upstream $commit"
else
  main_branch=$(git mainbranch)
  main_idx=$(git branch --sort=-committerdate --format="%(refname:short)" | awk -v b="$main_branch" '$1 == b {print NR; exit}')
  main_idx=${main_idx:-1}

  git branch --color=always --sort=-committerdate \
    --format="$branch $upstream $commit" |
    fzf --multi --ansi --no-sort --reverse \
      --preview="$preview" \
      --tiebreak begin \
      --bind="load:pos($main_idx)" \
      --bind='ctrl-d:preview-half-page-down' \
      --bind='ctrl-u:preview-half-page-up' \
      --bind='ctrl-x:execute(git drop {1})+transform: curr=$(git branch --show-current); idx=$(git branch --sort=-committerdate --format="%(refname:short)" | awk -v b="$curr" "$1 == b {print NR; exit}"); echo "reload(git branch --color=always --sort=-committerdate --format=\"'"$branch $upstream $commit"'\")+pos(${idx:-1})"' |
    awk '{print $1}'
fi

